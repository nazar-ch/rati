{
    "name": "rati",
    "version": "0.5.0",
    "description": "TypeScript frontend framework for React & MobX",
    "author": "Nazar Chobaniuk",
    "license": "MIT",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "exports": {
        ".": {
            "rati-dev": "./src/main.ts",
            "types": "./dist/main.d.ts",
            "import": "./dist/main.js",
            "source": "./src/main.ts"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "scripts": {
        "build": "vp build && yarn -T run tsc -p tsconfig.build.json",
        "watch": "yarn -T run tsc --watch",
        "test": "vp test run --typecheck",
        "test:watch": "vp test --typecheck"
    },
    "dependencies": {
        "type-fest": "^5.6.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-decorators": "^7.29.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@tsconfig/strictest": "^2.0.8",
        "@types/babel__core": "^7",
        "@types/react": "^19.2.14",
        "@types/react-dom": "~19.2.3",
        "jsdom": "^29.1.0",
        "mobx": "^6.15.0",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.2.5",
        "react-dom": "19.2.5",
        "vite": "catalog:",
        "vite-bundle-analyzer": "^1.3.8",
        "vite-plus": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "mobx": "^6.15.0",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.2"
    },
    "engines": {
        "node": ">=24"
    }
}
