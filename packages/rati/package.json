{
    "name": "rati",
    "version": "0.5.3",
    "description": "TypeScript frontend framework for React, with optional MobX bindings (rati/mobx)",
    "license": "MIT",
    "author": "Nazar Chobaniuk",
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "exports": {
        ".": {
            "rati-dev": "./src/main.ts",
            "types": "./dist/main.d.ts",
            "import": "./dist/main.js",
            "source": "./src/main.ts"
        },
        "./mobx": {
            "rati-dev": "./src/mobx/index.ts",
            "types": "./dist/mobx/index.d.ts",
            "import": "./dist/mobx/index.js",
            "source": "./src/mobx/index.ts"
        },
        "./ssr": {
            "rati-dev": "./src/ssr/index.ts",
            "types": "./dist/ssr/index.d.ts",
            "import": "./dist/ssr/index.js",
            "source": "./src/ssr/index.ts"
        },
        "./vite": {
            "rati-dev": "./src/vite/index.ts",
            "types": "./dist/vite/index.d.ts",
            "import": "./dist/vite/index.js",
            "source": "./src/vite/index.ts"
        },
        "./debug": {
            "rati-dev": "./src/debug/index.ts",
            "types": "./dist/debug/index.d.ts",
            "import": "./dist/debug/index.js",
            "source": "./src/debug/index.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vp build && yarn run -T tsgo -p tsconfig.build.json",
        "watch": "yarn run -T tsgo --watch",
        "typecheck": "yarn run -T tsgo --noEmit",
        "typecheck:test": "yarn run -T tsgo --noEmit -p tsconfig.test.json",
        "test": "vp test run --typecheck",
        "test:watch": "vp test --typecheck"
    },
    "dependencies": {
        "type-fest": "^5.7.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-decorators": "^7.29.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@tsconfig/strictest": "^2.0.8",
        "@types/babel__core": "^7",
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "~19.2.3",
        "fast-check": "^4.8.0",
        "jsdom": "^29.1.0",
        "mobx": "^6.16.1",
        "react": "^19.2.7",
        "react-dom": "19.2.7",
        "vite": "catalog:",
        "vite-bundle-analyzer": "^1.3.8",
        "vite-plus": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "mobx": "^6.15.0",
        "react": "^19.2",
        "react-dom": "^19.2",
        "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
    },
    "peerDependenciesMeta": {
        "mobx": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=24"
    }
}
