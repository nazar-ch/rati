{
    "private": true,
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "type": "module",
    "scripts": {
        "lint": "vp lint",
        "lint:types": "vp lint --type-aware",
        "fmt": "vp fmt",
        "typecheck": "yarn workspaces foreach -Ap run typecheck",
        "test": "yarn workspaces foreach -Ap run test",
        "upgrade": "yarn upgrade-interactive",
        "upgrade-yarn": "corepack use yarn@stable",
        "upgrade-node": "vp env install",
        "ci": "node scripts/ci.ts",
        "release": "./scripts/release.sh",
        "prepare": "vp config"
    },
    "devDependencies": {
        "typescript": "7.0.2",
        "vite-plus": "catalog:",
        "zx": "^8.8.5"
    },
    "resolutions": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "4.1.9"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "26",
            "onFail": "download"
        }
    },
    "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
