{
    "private": true,
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "type": "module",
    "scripts": {
        "lint": "vp lint",
        "lint:types": "vp lint --type-aware",
        "fmt": "vp fmt",
        "typecheck": "yarn workspaces foreach -Ap run typecheck",
        "test": "yarn workspaces foreach -Ap run test",
        "upgrade": "yarn upgrade-interactive",
        "upgrade-yarn": "corepack use yarn@stable",
        "upgrade-node": "vp env install",
        "release": "./scripts/release.sh",
        "prepare": "vp config"
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260421.2",
        "vite-plus": "catalog:"
    },
    "resolutions": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "4.1.9"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "26",
            "onFail": "download"
        }
    },
    "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
